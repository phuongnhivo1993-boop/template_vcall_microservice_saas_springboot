# =============================================================================
# VCall Contact Center - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Frontend ---
# API Gateway URL for Next.js rewrites
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080

# --- Database ---
# PostgreSQL password for all microservices
DB_PASSWORD=change_me

# JPA / Hibernate
JPA_SHOW_SQL=false
JPA_DDL_AUTO=validate

# --- JWT ---
# Secret key for JWT token signing (min 256 bits / 64 hex chars)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970337336763979244226452948404D635166546A576E5A7234753778214125442A47

# --- Encryption ---
# AES encryption key (32 bytes / 64 hex chars)
ENCRYPTION_SECRET=mySecretKey12345mySecretKey12345mySe

# --- CORS ---
# Comma-separated allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Kafka ---
# Comma-separated list of trusted packages for Kafka deserialization
KAFKA_TRUSTED_PACKAGES=com.vcall.common.dto

# --- MinIO ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_URL=http://localhost:9000
MINIO_BUCKET=recordings



# --- Email (Email Service & Notification Service) ---
# SMTP configuration for sending emails
# Production example (Gmail SMTP):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your-email@gmail.com
#   MAIL_PASSWORD=your-app-password
# Production example (SendGrid):
#   MAIL_HOST=smtp.sendgrid.net
#   MAIL_PORT=587
#   MAIL_USERNAME=apikey
#   MAIL_PASSWORD=SG.xxxxx
# Production example (AWS SES):
#   MAIL_HOST=email-smtp.us-east-1.amazonaws.com
#   MAIL_PORT=587
#   MAIL_USERNAME=AKIAxxxxx
#   MAIL_PASSWORD=xxxxx
MAIL_HOST=${MAIL_HOST:-smtp.example.com}
MAIL_PORT=${MAIL_PORT:-587}
MAIL_USERNAME=${MAIL_USERNAME:-noreply@example.com}
MAIL_PASSWORD=${MAIL_PASSWORD:-change_me}
MAIL_SMTP_AUTH=${MAIL_SMTP_AUTH:-true}
MAIL_SMTP_STARTTLS=${MAIL_SMTP_STARTTLS:-true}
MAIL_FROM=${MAIL_FROM:-noreply@vcall.io}
MAIL_FROM_NAME=${MAIL_FROM_NAME:-VCall Contact Center}

# Firebase FCM
FIREBASE_PROJECT_ID=${FIREBASE_PROJECT_ID:-}
FIREBASE_CONFIG_PATH=${FIREBASE_CONFIG_PATH:-firebase-service-account.json}
FIREBASE_DATABASE_URL=${FIREBASE_DATABASE_URL:-}

# --- Eureka / Service Discovery ---
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/

# --- Docker Compose (optional — override defaults) ---
# Used in docker-compose files; defaults to vcall@123 / minioadmin if unset
# DB_PASSWORD is shared above with the microservices
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Grafana ---
GRAFANA_ADMIN_USER=${GRAFANA_ADMIN_USER:-admin}
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD:-admin}

# --- Config Server ---
CONFIG_SERVER_URI=http://localhost:8888

# --- Monitoring ---
# Prometheus / Grafana are pre-configured in docker-compose
# Dashboards available at http://localhost:3000 (admin/admin)
